generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  code        String    @unique @db.Char(3)
  groupName   String?   @map("group_name") @db.Char(1)
  flagUrl     String?   @map("flag_url")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  players     Player[]
  homeMatches Match[]   @relation("HomeTeam")
  awayMatches Match[]   @relation("AwayTeam")

  @@map("teams")
}

model Player {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  teamId       String    @map("team_id") @db.Uuid
  position     String?
  shirtNumber  Int?      @map("shirt_number")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  team               Team                @relation(fields: [teamId], references: [id])
  matchEvents        MatchEvent[]
  predictionPlayers  PredictionPlayer[]

  @@map("players")
}

model Match {
  id              String    @id @default(uuid()) @db.Uuid
  homeTeamId      String    @map("home_team_id") @db.Uuid
  awayTeamId      String    @map("away_team_id") @db.Uuid
  matchDate       DateTime  @map("match_date") @db.Timestamptz
  bettingClosesAt DateTime? @map("betting_closes_at") @db.Timestamptz
  stage           String
  groupName       String?   @map("group_name") @db.Char(1)
  venue           String?
  status          String    @default("upcoming")
  homeScore       Int?      @map("home_score")
  awayScore       Int?      @map("away_score")
  isScored        Boolean   @default(false) @map("is_scored")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  homeTeam     Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  matchEvents  MatchEvent[]
  predictions  Prediction[]

  @@map("matches")
}

model MatchEvent {
  id        String   @id @default(uuid()) @db.Uuid
  matchId   String   @map("match_id") @db.Uuid
  playerId  String   @map("player_id") @db.Uuid
  eventType String   @map("event_type")
  minute    Int?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  match  Match  @relation(fields: [matchId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@map("match_events")
}

model Profile {
  id           String    @id @db.Uuid
  username     String    @unique @db.VarChar(30)
  displayName  String?   @map("display_name")
  avatarUrl    String?   @map("avatar_url")
  isAdmin      Boolean   @default(false) @map("is_admin")
  totalPoints  Int       @default(0) @map("total_points")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  predictions Prediction[]

  @@map("profiles")
}

model ScoringRule {
  id          String @id @default(uuid()) @db.Uuid
  ruleKey     String @unique @map("rule_key")
  points      Int
  description String

  @@map("scoring_rules")
}

model Prediction {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  matchId              String    @map("match_id") @db.Uuid
  predictedWinner      String?   @map("predicted_winner")
  predictedHomeScore   Int?      @map("predicted_home_score")
  predictedAwayScore   Int?      @map("predicted_away_score")
  pointsEarned         Int       @default(0) @map("points_earned")
  isScored             Boolean   @default(false) @map("is_scored")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  user              Profile            @relation(fields: [userId], references: [id])
  match             Match              @relation(fields: [matchId], references: [id])
  predictionPlayers PredictionPlayer[]

  @@unique([userId, matchId])
  @@map("predictions")
}

model PredictionPlayer {
  id           String   @id @default(uuid()) @db.Uuid
  predictionId String   @map("prediction_id") @db.Uuid
  playerId     String   @map("player_id") @db.Uuid
  eventType    String   @map("event_type")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  prediction Prediction @relation(fields: [predictionId], references: [id])
  player     Player     @relation(fields: [playerId], references: [id])

  @@map("prediction_players")
}
